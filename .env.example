# Copy this file to .env and fill in your API keys

# Azure Speech Service
AZURE_SPEECH_KEY=your_azure_speech_key_here
AZURE_SPEECH_REGION=eastasia

# Anthropic Claude
# 方式 A：直接使用 Anthropic 官方 API
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# 方式 B：通过 OpenRouter 代理（填写后方式A的KEY留空即可）
ANTHROPIC_AUTH_TOKEN=sk-or-v1-your_openrouter_key_here
ANTHROPIC_BASE_URL=https://openrouter.ai/api

# 模型名（OpenRouter 格式示例：anthropic/claude-sonnet-4-5）
ANTHROPIC_MODEL=claude-sonnet-4-6

# Azure TTS Voice (optional, default: en-US-JennyNeural)
AZURE_TTS_VOICE=en-US-JennyNeural

# Whisper model size: tiny/base/small/medium/large
# 运行前请先执行 `.\\.venv\\Scripts\\python.exe scripts\\install_models.py`
# 将模型安装到项目本地目录。运行时不会再自动联网下载。
# "large" is the highest standard accuracy option here, but it is slower.
WHISPER_MODEL=base
